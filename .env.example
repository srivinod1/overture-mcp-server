# Overture Maps MCP Server — Environment Variables
# Copy this file to .env and fill in values for your deployment.

# --- Required for hosted transports (SSE/HTTP) ---
# Generate a strong key: openssl rand -hex 32
OVERTURE_API_KEY=

# --- Transport ---
# Options: stdio (default, local), sse (hosted), http (hosted)
TRANSPORT=stdio

# --- Tool Mode ---
# Options: direct (default, 13 individual tools), progressive (3 meta-tools)
TOOL_MODE=direct

# --- Server (SSE/HTTP only) ---
PORT=8000
HOST=0.0.0.0

# --- Data ---
# Overture Maps release version (quarterly updates)
OVERTURE_DATA_VERSION=2026-01-21.0

# --- Limits ---
MAX_CONCURRENT_QUERIES=3
MAX_RADIUS_M=50000
